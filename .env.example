# Zenskar Marketing Analytics MCP Server — Environment Variables
# Copy this to .env and fill in your values.

# ── Google Service Account (for GSC + GA4) ──────────────────────
# Path to service account JSON file, OR inline JSON string
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

# ── Google Search Console ───────────────────────────────────────
GSC_SITE_URL=https://www.zenskar.com/

# ── Google Analytics 4 ──────────────────────────────────────────
GA4_PROPERTY_ID=428507848

# ── Google Ads ──────────────────────────────────────────────────
ADS_CUSTOMER_ID=5860587550
ADS_DEV_TOKEN=your-dev-token-here
# Path to OAuth2 token JSON file (contains client_id, client_secret, refresh_token)
ADS_TOKEN_FILE=google_ads_token.json
# OR inline JSON (for cloud): ADS_TOKEN_JSON={"client_id":"...","client_secret":"...","refresh_token":"..."}

# ── HubSpot ─────────────────────────────────────────────────────
HUBSPOT_PAT=pat-na1-your-token-here

# ── Bing Webmaster Tools ────────────────────────────────────────
BING_API_KEY=your-bing-api-key-here
